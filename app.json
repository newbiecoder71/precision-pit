{
  "expo": {
    "name": "Precision Pit",
    "slug": "precision-pit",
    "scheme": "precisionpit",
    "orientation": "default",
    "icon": "./assets/logo/app-icon1-lowered.png",
    "splash": {
      "backgroundColor": "#0D1117"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "bundleIdentifier": "com.newbiecoder71.precisionpit",
      "supportsTablet": true,
      "splash": {
        "backgroundColor": "#0D1117"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/app-icon1-lowered.png",
        "backgroundColor": "#0D1117"
      },
      "splash": {
        "backgroundColor": "#0D1117"
      },
      "package": "com.newbiecoder71.precisionpit"
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "5bb96212-bda6-43dd-baf7-e737490aeefa"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5bb96212-bda6-43dd-baf7-e737490aeefa"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
